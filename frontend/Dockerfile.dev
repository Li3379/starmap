# 前端 Dockerfile（开发，HMR）
FROM node:20-alpine

# 设置 UTF-8 locale，确保中文正确处理
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

WORKDIR /app

# 先拷依赖文件利用层缓存
COPY package.json package-lock.json* ./
RUN npm install

# 源码由 volume 挂载，不在这里 COPY

EXPOSE 5173

# 命令由 docker-compose 指定（npm run dev --host 0.0.0.0）
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
