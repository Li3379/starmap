{
  "name": "starmap-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript ../starmap-contracts/openapi.yaml -o src/api/schema.ts"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "element-plus": "^2.6.0",
    "@antv/g6": "^5.0.0",
    "echarts": "^5.5.0",
    "vue-echarts": "^6.6.0",
    "axios": "^1.6.0",
    "msw": "^2.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.2.0",
    "typescript": "^5.4.0",
    "vue-tsc": "^2.0.0",
    "@types/node": "^20.11.0",
    "openapi-typescript": "^6.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "vue-eslint-parser": "^9.4.0",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "vitest": "^1.4.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.0.0",
    "sass": "^1.72.0"
  }
}
